# ============================================================
# TimeWin — Configuration Production
# ============================================================
# Copiez ce fichier vers .env.production et remplissez les valeurs
#   cp .env.production.example .env.production
# ============================================================

# ---- Domaine ----
DOMAIN=timewin.example.com
SSL_EMAIL=admin@example.com

# ---- Base de données ----
POSTGRES_USER=timewin
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_securise_32_chars
POSTGRES_DB=timewin

# ---- Next.js / NextAuth ----
# DATABASE_URL est construit automatiquement par docker-compose.prod.yml
NEXTAUTH_SECRET=CHANGEZ_MOI_chaine_aleatoire_minimum_32_caracteres
NEXTAUTH_URL=https://timewin.example.com
